/**
 * Genesis AI Micro-Game Engine - HarmonyOS Module Configuration
 *
 * 此文件为 HarmonyOS 元服务 (MetaAbility) 的模块配置参考。
 * 在实际项目中，此文件应放置于 entry/src/main/module.json5。
 *
 * 文档参考：https://developer.harmonyos.com/cn/docs/documentation/doc-guides/module-config-0000001478061365
 */
{
  "module": {
    // ==================== 基本信息配置 ====================

    "name": "entry",
    "type": "entry",
    "description": "$string:module_desc",

    "mainElement": "EntryAbility",

    // 支持的设备类型
    "deviceTypes": [
      "phone",
      "tablet"
    ],

    // 安装时交付（元服务必须为 true）
    "deliveryWithInstall": true,

    // 免安装支持（元服务核心特性，必须为 true）
    "installationFree": true,

    // 页面路由配置文件
    "pages": "$profile:main_pages",

    // ==================== 应用权限声明 ====================

    "requestPermissions": [
      {
        // 网络访问权限（系统授权）
        "name": "ohos.permission.INTERNET",
        "reason": "$string:permission_internet_reason",
        "usedScene": {
          "abilities": ["EntryAbility"],
          "when": "inuse"
        }
      },
      {
        // 网络状态获取（系统授权）
        "name": "ohos.permission.GET_NETWORK_INFO",
        "reason": "$string:permission_network_reason",
        "usedScene": {
          "abilities": ["EntryAbility"],
          "when": "inuse"
        }
      },
      {
        // 电池信息（系统授权）—— 用于 TriggerEngine 根据电量调整触发策略
        "name": "ohos.permission.GET_BATTERY_INFO",
        "reason": "$string:permission_battery_reason",
        "usedScene": {
          "abilities": ["EntryAbility"],
          "when": "inuse"
        }
      },
      {
        // 大致位置（用户授权）—— 用于天气、地域触发器
        "name": "ohos.permission.APPROXIMATELY_LOCATION",
        "reason": "$string:permission_location_reason",
        "usedScene": {
          "abilities": ["EntryAbility"],
          "when": "inuse"
        }
      }
    ],

    // ==================== Ability 配置 ====================

    "abilities": [
      {
        "name": "EntryAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "description": "$string:EntryAbility_desc",
        "icon": "$media:icon",
        "label": "$string:EntryAbility_label",

        // 启动页配置
        "startWindowIcon": "$media:startIcon",
        "startWindowBackground": "$color:startWindowBackgroundColor",

        // 允许被外部调用
        "exported": true,

        // 技能声明 —— 定义 Ability 可响应的意图
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "action.system.home"
            ]
          }
        ],

        // 元数据 —— 声明服务卡片配置
        "metadata": [
          {
            "name": "ohos.extension.form",
            "resource": "$profile:form_config"
          }
        ],

        // 支持的窗口模式
        "modes": {
          "defaultMode": "fullscreen"
        },

        // 主题配置
        "theme": {
          "colorMode": "dark"
        }
      }
    ],

    // ==================== ExtensionAbility 配置 ====================

    "extensionAbilities": [
      {
        "name": "GameWidgetAbility",
        "srcEntry": "./ets/widget/GameWidget.ets",
        "icon": "$media:icon",
        "label": "$string:widget_label",
        "description": "$string:widget_desc",

        // 类型为 form（服务卡片）
        "type": "form",

        // 允许被外部调用
        "exported": true,

        // 元数据 —— 引用服务卡片配置文件
        "metadata": [
          {
            "name": "ohos.extension.form",
            "resource": "$profile:form_config"
          }
        ]
      }
    ],

    // ==================== 代理配置 ====================

    "proxy": {
      "services": []
    }
  }
}

// ==================== 伴随配置文件说明 ====================

